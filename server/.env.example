# Server Environment Variables
# MONGO_URI and JWT_SECRET are REQUIRED.
# CORS_ORIGIN is REQUIRED for production — comma-separated list of allowed origins.

PORT=5000
MONGO_URI=mongodb://localhost:27017/scholarsync
JWT_SECRET=your-jwt-secret-here
ADMIN_PASSWORD=your-admin-password
UTILITY_PASSWORD=your-utility-password
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:5175
